{
  "manifest_version": 3,
  "name": "MangaBuff Helper",
  "version": "1.0.0",
  "description": "Автоматизация действий на MangaBuff: шахта, комментарии, читалка манги",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://mangabuff.ru/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mangabuff.ru/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["quiz-answers.json"],
      "matches": ["https://mangabuff.ru/*"]
    }
  ]
}

